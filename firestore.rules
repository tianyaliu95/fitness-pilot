rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userKey}/data/{doc} {
      allow read, write: if request.auth != null && (
        // Email-based path (preferred for console readability)
        (request.auth.token.email != null
          && request.auth.token.email.lower() == userKey.lower())
        // Legacy uid-based path (migration)
        || request.auth.uid == userKey
      );
    }
  }
}
